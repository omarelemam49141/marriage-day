# Marriage day: Saturday 21 March 2026. Adjust time to your timezone if needed.
# Example: 2026-03-21T20:00:00
NEXT_PUBLIC_MARRIAGE_DATE=2026-03-21T20:00:00

# RSVP email: prefer Resend API (see below). If using static host (e.g. GitHub Pages), fallback uses EmailJS.
# EmailJS (free tier): https://www.emailjs.com/ – 1) Add Email Service, 2) Create template with {{name}} (simple "I will come to the house" text for RSVP), 3) Copy IDs
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
# Optional: use a different EmailJS template for "come to home" RSVP (only name, no quiz). If unset, TEMPLATE_ID is used.
# NEXT_PUBLIC_EMAILJS_RSVP_TEMPLATE_ID=your_rsvp_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# Server-side email (RSVP + mosque quiz) via Resend. Sign up at https://resend.com
# Create an API key, verify your domain (or use onboarding domain for testing), then set:
RESEND_API_KEY=re_xxxxxxxxxxxx
# Optional: override recipient and sender (defaults used if not set)
# RSVP_TO_EMAIL=omarelemam49141@gmail.com
# RSVP_FROM_EMAIL=Ishhar <onboarding@resend.dev>
