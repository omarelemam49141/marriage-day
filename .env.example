# Marriage day: Saturday 21 March 2026. Adjust time to your timezone if needed.
# Example: 2026-03-21T20:00:00
NEXT_PUBLIC_MARRIAGE_DATE=2026-03-21T20:00:00

# EmailJS (free tier): https://www.emailjs.com/
# TEMPLATE_ID = mosque quiz emails only.
# RSVP_TEMPLATE_ID = "come to home" only. Create a SEPARATE template in EmailJS with just "تلبية دعوة البيت" + {{name}} (no quiz, no questions).
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_quiz_template_id
NEXT_PUBLIC_EMAILJS_RSVP_TEMPLATE_ID=your_rsvp_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# Optional: Resend for mosque quiz server-side email only. Not used for "come to home" (that uses EmailJS above).
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RSVP_TO_EMAIL=...
# RSVP_FROM_EMAIL=...
